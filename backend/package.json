{
  "name": "backend",
  "version": "1.0.0",
  "author": "Vitor Valentim da Silva Ferreira",
  "scripts": {
    "start:dev": "nest start --debug --watch",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "test:unit": "jest",
    "test:e2e": "jest --config test/e2e/jest-e2e.json",
    "test:integration": "jest --config test/integration/jest-integration.json",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "knip:check": "knip",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nestjs": "^10.58.0",
    "@sentry/profiling-node": "^10.58.0",
    "@neondatabase/serverless": "^1.1.0",
    "swagger-ui-express": "^5.0.1",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "posthog-node": "^5.38.1",
    "joi": "^18.2.3",
    "pino-http": "^11.0.0",
    "nestjs-pino": "^4.6.1",
    "helmet": "^8.2.0",
    "compression": "^1.8.1",
    "async-retry": "^1.3.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/node": "^25.9.3",
    "@types/express": "^5.0.6",
    "@types/async-retry": "^1.4.9",
    "@types/jest": "^30.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.4",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "knip": "^6.17.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "lint-staged": "^17.0.7",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.8.17",
    "pino-pretty": "^13.1.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./src",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
