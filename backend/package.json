{
  "name": "backend",
  "version": "1.0.0",
  "author": "Vitor Valentim da Silva Ferreira",
  "scripts": {
    "start:dev": "nest start --watch --sourceRoot . --entryFile backend/src/main",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "test:unit": "jest",
    "test:e2e": "jest --config test/e2e/jest-e2e.json",
    "test:integration": "jest --config test/integration/jest-integration.json",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "knip:check": "knip",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@prisma/adapter-neon": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@upstash/qstash": "^2.11.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@sentry/nestjs": "^10.67.0",
    "@sentry/profiling-node": "^10.67.0",
    "@neondatabase/serverless": "^1.1.0",
    "swagger-ui-express": "^5.0.1",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "posthog-node": "^5.46.0",
    "joi": "^18.2.3",
    "pino-http": "^11.0.0",
    "nestjs-pino": "^4.6.1",
    "helmet": "^8.3.0",
    "compression": "^1.8.1",
    "async-retry": "^1.3.3",
    "svix": "^1.98.0",
    "nestjs-zod": "^5.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/node": "^26.1.1",
    "@types/express": "^5.0.6",
    "@types/async-retry": "^1.4.9",
    "@types/jest": "^30.0.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.9.5",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "knip": "^6.27.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "lint-staged": "^17.1.0",
    "prisma": "^7.9.0",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.9.1",
    "pino-pretty": "^13.1.3",
    "npm-check-updates": "^22.2.9"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./src",
    "moduleNameMapper": {
      "^@/enum/(.*)$": "<rootDir>/../../shared/enum/$1",
      "^@/error/(.*)$": "<rootDir>/../../shared/error/$1",
      "^@/const/(.*)$": "<rootDir>/../../shared/const/$1",
      "^@/dto/(.*)$": "<rootDir>/../../shared/dto/$1",
      "^@/locale/(.*)$": "<rootDir>/../../shared/locale/$1",
      "^@/bootstrap/(.*)$": "<rootDir>/bootstrap/$1",
      "^@/config/(.*)$": "<rootDir>/config/$1",
      "^@/module/(.*)$": "<rootDir>/module/$1",
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "diagnostics": false
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
