{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../../",
  "testEnvironment": "node",
  "testRegex": "test/integration/.*\\.integration\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/enum/(.*)$": "<rootDir>/../shared/enum/$1",
    "^@/(.*)$": "<rootDir>/src/$1"
  }
}
