{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../../",
  "testEnvironment": "node",
  "testRegex": "test/integration/.*\\.integration\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^@/bootstrap/(.*)$": "<rootDir>/src/bootstrap/$1",
    "^@/config/(.*)$": "<rootDir>/src/config/$1",
    "^@/enum/(.*)$": "<rootDir>/../shared/enum/$1",
    "^@/error/(.*)$": "<rootDir>/../shared/error/$1",
    "^@/const/(.*)$": "<rootDir>/../shared/const/$1",
    "^@/dto/(.*)$": "<rootDir>/../shared/dto/$1"
  }
}
