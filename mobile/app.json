{
  "expo": {
    "name": "voice-vault",
    "slug": "voice-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "",
    "scheme": "voice-vault",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["asset/**/*"],
    "ios": {
      "icon": "",
      "bundleIdentifier": "com.vitorvalem.voicevault",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.vitorvalem.voicevault",
      "googleServicesFile": "./google-services.json",
      "icon": "./asset/voice-vault-favicon.png",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": ""
    },
    "plugins": [
      "@clerk/expo",
      "expo-web-browser",
      "expo-notifications",
      "expo-localization",
      "expo-status-bar",
      "expo-secure-store",
      "expo-router",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "vitorvalem"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0d0b1a",
          "image": "./asset/voice-vault-favicon.png",
          "imageWidth": 94,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./asset/font/plus_jakarta_sans_extra_light.ttf",
            "./asset/font/plus_jakarta_sans_extra_light_italic.ttf",
            "./asset/font/plus_jakarta_sans_light.ttf",
            "./asset/font/plus_jakarta_sans_light_italic.ttf",
            "./asset/font/plus_jakarta_sans_regular.ttf",
            "./asset/font/plus_jakarta_sans_italic.ttf",
            "./asset/font/plus_jakarta_sans_medium.ttf",
            "./asset/font/plus_jakarta_sans_medium_italic.ttf",
            "./asset/font/plus_jakarta_sans_semi_bold.ttf",
            "./asset/font/plus_jakarta_sans_semi_bold_italic.ttf",
            "./asset/font/plus_jakarta_sans_bold.ttf",
            "./asset/font/plus_jakarta_sans_bold_italic.ttf",
            "./asset/font/plus_jakarta_sans_extra_bold.ttf",
            "./asset/font/plus_jakarta_sans_extra_bold_italic.ttf",
            "./asset/font/plus_jakarta_sans_black.ttf",
            "./asset/font/plus_jakarta_sans_black_italic.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000
    },
    "owner": "vitorvalem"
  }
}
