{
  "name": "voice-vault",
  "version": "1.0.0",
  "author": "Vitor Valentim da Silva Ferreira",
  "description": "Voice Vault is a secure and user-friendly application that allows users to store and manage their voice recordings with ease. It provides a seamless experience for recording, organizing, and accessing voice memos, ensuring privacy and security for sensitive information.",
  "license": "MIT",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "knip:check": "knip",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "zod": "^4.4.3",
    "nestjs-zod": "^5.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint": "^10.5.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "ts-node": "^10.9.2",
    "knip": "^6.20.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "globals": "^17.7.0",
    "npm-check-updates": "^22.2.7"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
